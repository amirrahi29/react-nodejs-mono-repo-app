# Local API — copy to .env (never commit .env).
PORT=4000

# --- Option A: Key Vault (same env names as Kubernetes) ---
# Full vault URI, e.g. https://your-vault.vault.azure.net/
# AZURE_KEY_VAULT_URL=
# Names of secrets *inside* the vault (not the password text):
# KEY_VAULT_USERNAME_SECRET=username
# KEY_VAULT_PASSWORD_SECRET=password
# Local dev: az login + DefaultAzureCredential. AKS: Workload Identity + AZURE_CLIENT_ID.

# --- Option B: No vault — plain creds ---
# APP_USERNAME=
# APP_PASSWORD=
