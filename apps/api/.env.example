# Local API — copy to .env (never commit .env).
PORT=4000

# --- Key Vault ---
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net
# or: AZURE_KEYVAULT_URI=...
# KEY_VAULT_USERNAME_SECRET=username
# KEY_VAULT_PASSWORD_SECRET=password
# AKS: AZURE_CLIENT_ID=<UAMI client id> with Workload Identity
# CI: Key Vault is wired in Helm only if vault URL + WI client id + service account name are all in GitHub secrets.

# --- No vault ---
# APP_USERNAME=
# APP_PASSWORD=
# (K8s secret may use lowercase keys username / password)
