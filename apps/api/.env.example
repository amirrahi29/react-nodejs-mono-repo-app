# Local API — copy to .env (never commit .env).
PORT=4000

# --- Key Vault (same vars as Kubernetes) ---
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net
# Optional alias:
# AZURE_KEYVAULT_URI=https://your-vault.vault.azure.net
# Names of secrets *inside* the vault:
# KEY_VAULT_USERNAME_SECRET=username
# KEY_VAULT_PASSWORD_SECRET=password
# AKS Workload Identity (pod): AZURE_CLIENT_ID=<UAMI client id>

# --- No vault: plain creds ---
# APP_USERNAME=
# APP_PASSWORD=
